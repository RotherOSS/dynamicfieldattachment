#. Template: AdminDynamicFieldAttachment
msgid "Field"
msgstr "Mező"

#. Template: AdminDynamicFieldAttachment
msgid "Maximum amount of attachments"
msgstr "Mellékletek legnagyobb száma"

#. Template: AdminDynamicFieldAttachment
msgid "Change this, if you need more or less attachments to be stored in this dynamic field."
msgstr "Változtassa meg, ha több vagy kevesebb mellékletet szükséges tárolni ebben a dinamikus mezőben."

#. Template: AdminDynamicFieldAttachment
msgid "Maximum attachment size"
msgstr "Legnagyobb mellékletméret"

#. Template: AdminDynamicFieldAttachment
msgid "Maximum size per attachment in MB for this dynamic field. 0 for no limit."
msgstr "Legnagyobb méret mellékletenként MB-ban ennél a dinamikus mezőnél. A 0 azt jelenti, hogy nincs korlát."

#. Perl Module: Kernel/Modules/AdminDynamicFieldAttachment.pm
msgid "The maximum of attachments for this dynamic field of type attachment must be a positive number."
msgstr "A mellékletek legnagyobb számának ennél a melléklet típusú dinamikus mezőnél pozitív számnak kell lennie."

#. Perl Module: Kernel/Modules/AdminDynamicFieldAttachment.pm
msgid "The maximum attachment size for this dynamic field of type attachment must be a positive number."
msgstr "A legnagyobb mellékletméretnek ennél a melléklet típusú dinamikus mezőnél pozitív számnak kell lennie."

#. Perl Module: Kernel/Modules/AdminDynamicFieldAttachment.pm
msgid "Need ValidID!"
msgstr "Érvényességazonosító szükséges!"

#. Perl Module: Kernel/Modules/AdminDynamicFieldAttachment.pm
msgid "Could not create the new field."
msgstr "Nem sikerült létrehozni az új mezőt."

#. Perl Module: Kernel/Modules/AdminDynamicFieldAttachment.pm
msgid "Need ID!"
msgstr "Azonosító szükséges!"

#. Perl Module: Kernel/Modules/AdminDynamicFieldAttachment.pm
msgid "Could not get data for dynamic field %s!"
msgstr "Nem sikerült lekérni az adatokat a(z) %s dinamikus mezőhöz!"

#. Perl Module: Kernel/Modules/AdminDynamicFieldAttachment.pm
msgid "Could not update the field %s!"
msgstr "Nem sikerült frissíteni a(z) %s mezőt!"

#. Perl Module: Kernel/Modules/AjaxDynamicFieldAttachment.pm
msgid "Success"
msgstr "Sikerült"

